# Database
POSTGRES_USER=workflow
POSTGRES_PASSWORD=workflow123
POSTGRES_DB=workflow_automation
DATABASE_URL=postgresql+asyncpg://workflow:workflow123@localhost:5432/workflow_automation

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security
SECRET_KEY=change-this-in-production-min-32-chars-long
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
UPLOAD_DIR=./uploads

# Email / SMTP Configuration (opcional - para envio de emails)
# Exemplos de providers:
# Gmail:     SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# Outlook:   SMTP_HOST=smtp.office365.com, SMTP_PORT=587
# AWS SES:   SMTP_HOST=email-smtp.us-east-1.amazonaws.com, SMTP_PORT=587
#
# IMPORTANTE: Para Gmail, use "App Password" (senha de aplicativo), não a senha normal!
# Crie em: https://myaccount.google.com/apppasswords

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-app-aqui
SMTP_FROM=seu-email@gmail.com

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=.csv,.json,.xml,.pdf,.txt
